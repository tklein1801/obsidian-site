---
import '../styles/global.css';
import '@xyflow/react/dist/style.css';
import Sidebar from '../components/Sidebar.astro';
import SearchModal from '../components/SearchModal';
import { getVaultIndex, buildSearchIndex } from '../lib/vault';
import { siteConfig } from '../../vault.config';

interface Props {
  title: string;
  description?: string;
  currentSlug?: string;
}

const { title, description = siteConfig.description, currentSlug } = Astro.props;
const index = getVaultIndex();
const searchData = buildSearchIndex(index);
const c = siteConfig.colors;
const colorVars = `:root{--bg-primary:${c.bgPrimary};--bg-secondary:${c.bgSecondary};--bg-tertiary:${c.bgTertiary};--accent:${c.accent};--link:${c.link};}`;

// Mermaid theme variables derived from site colours
const mermaidTheme = JSON.stringify({
  background:        c.bgSecondary,
  primaryColor:      c.bgTertiary,
  primaryTextColor:  '#dcddde',
  primaryBorderColor:'rgba(255,255,255,0.12)',
  lineColor:         'rgba(255,255,255,0.35)',
  secondaryColor:    c.bgPrimary,
  tertiaryColor:     c.bgTertiary,
  edgeLabelBackground: c.bgSecondary,
  clusterBkg:        c.bgTertiary,
  titleColor:        '#dcddde',
  nodeTextColor:     '#dcddde',
  fontFamily:        'Inter, ui-sans-serif, system-ui, sans-serif',
});---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} – {siteConfig.siteName}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;1,14..32,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <Fragment set:html={`<style>${colorVars}</style>`} />
  <!-- Mermaid: initialise with site colour palette, only load when diagrams are present -->
  <Fragment set:html={`<script type="module">
    if (document.querySelector('pre.mermaid')) {
      const { default: mermaid } = await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs');
      mermaid.initialize({
        startOnLoad: true,
        theme: 'base',
        themeVariables: ${mermaidTheme},
        securityLevel: 'loose',
        fontFamily: 'Inter, ui-sans-serif, system-ui, sans-serif',
      });
    }
  </script>`} />
</head>
<body style="display:flex;height:100vh;overflow:hidden;background:var(--bg-primary);color:var(--text-primary);">

  <!-- Mobile overlay -->
  <div id="sidebar-overlay"
    style="display:none;position:fixed;inset:0;z-index:40;background:rgba(0,0,0,0.65);"
    onclick="closeSidebar()">
  </div>

  <!-- Left sidebar -->
  <aside id="sidebar"
    style="width:var(--sidebar-w);flex-shrink:0;height:100vh;overflow:hidden;position:relative;z-index:50;transition:transform 0.2s ease;"
    class="hidden lg:block">
    <Sidebar currentSlug={currentSlug} />
  </aside>

  <!-- Mobile sidebar (hidden by default) -->
  <aside id="sidebar-mobile"
    style="width:var(--sidebar-w);flex-shrink:0;height:100vh;overflow:hidden;position:fixed;left:0;top:0;z-index:50;transform:translateX(-100%);transition:transform 0.2s ease;"
    class="lg:hidden">
    <Sidebar currentSlug={currentSlug} />
  </aside>

  <!-- Main area -->
  <div style="flex:1;min-width:0;display:flex;flex-direction:column;height:100vh;overflow:hidden;">

    <!-- Mobile header (hidden on desktop) -->
    <header class="mobile-header lg:hidden">
      <button onclick="openSidebar()"
        style="padding:6px;border-radius:6px;background:none;border:none;cursor:pointer;color:var(--text-muted);"
        aria-label="Open menu">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
      <span class="mobile-header-title">{siteConfig.siteName}</span>
      <button id="mobile-search-btn"
        style="padding:6px;border-radius:6px;background:none;border:none;cursor:pointer;color:var(--text-muted);"
        aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"/><path d="m21 21-4.35-4.35"/>
        </svg>
      </button>
    </header>

    <!-- Scrollable page content -->
    <main style="flex:1;overflow-y:auto;">
      <slot />
    </main>
  </div>

  <!-- Search modal -->
  <SearchModal client:load searchData={searchData} />

</body>
</html>

<script>
  function openSidebar() {
    const s = document.getElementById('sidebar-mobile');
    const o = document.getElementById('sidebar-overlay');
    if (s) s.style.transform = 'translateX(0)';
    if (o) o.style.display = 'block';
  }
  function closeSidebar() {
    const s = document.getElementById('sidebar-mobile');
    const o = document.getElementById('sidebar-overlay');
    if (s) s.style.transform = 'translateX(-100%)';
    if (o) o.style.display = 'none';
  }
  (window as unknown as Record<string, unknown>).openSidebar = openSidebar;
  (window as unknown as Record<string, unknown>).closeSidebar = closeSidebar;

  // ⌘K / Ctrl+K
  document.addEventListener('keydown', e => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      (document.getElementById('search-btn') as HTMLElement)?.click();
    }
  });
  document.getElementById('mobile-search-btn')?.addEventListener('click', () => {
    (document.getElementById('search-btn') as HTMLElement)?.click();
  });

  // Copy buttons for code blocks
  document.querySelectorAll('pre').forEach(pre => {
    const wrap = document.createElement('div');
    wrap.style.cssText = 'position:relative;';
    pre.parentNode!.insertBefore(wrap, pre);
    wrap.appendChild(pre);

    const btn = document.createElement('button');
    btn.textContent = 'Copy';
    btn.setAttribute('aria-label', 'Copy code');
    btn.style.cssText = [
      'position:absolute;top:0.5rem;right:0.5rem;',
      'padding:2px 8px;font-size:10px;font-family:inherit;',
      'border-radius:4px;cursor:pointer;',
      'background:var(--bg-tertiary);color:var(--text-faint);',
      'border:1px solid var(--border);opacity:0;pointer-events:none;',
      'transition:opacity 0.15s;',
    ].join('');
    wrap.addEventListener('mouseenter', () => { btn.style.opacity = '1'; btn.style.pointerEvents = 'auto'; });
    wrap.addEventListener('mouseleave', () => { btn.style.opacity = '0'; btn.style.pointerEvents = 'none'; });
    btn.addEventListener('click', async () => {
      await navigator.clipboard.writeText(pre.querySelector('code')?.innerText ?? pre.innerText);
      btn.textContent = '✓ Copied';
      btn.style.color = 'var(--accent)';
      setTimeout(() => { btn.textContent = 'Copy'; btn.style.color = 'var(--text-faint)'; }, 2000);
    });
    wrap.appendChild(btn);
  });
</script>
